# CPU-only test image for sudoku-ocr.
#
# Installs a built wheel (not an editable dev install) and contains only
# tests/ (including tests/testdata/images/) — no source tree.  Model weights are bundled inside
# the wheel (see pyproject.toml [tool.hatch.build.targets.wheel] artifacts).
#
# Build:
#   docker build -f Dockerfile.test -t sudoku-ocr-test .
#
# Run all tests:
#   docker run --rm sudoku-ocr-test
#
# Run a specific category:
#   docker run --rm sudoku-ocr-test pytest tests/ -k screenshot -v


# ── Stage 1: build wheel ──────────────────────────────────────────────────────
FROM python:3.12-slim AS builder

WORKDIR /build

RUN pip install --no-cache-dir build

COPY src/ src/
COPY pyproject.toml .

RUN python -m build --wheel --outdir /dist


# ── Stage 2: test runner ──────────────────────────────────────────────────────
FROM python:3.12-slim

WORKDIR /app

# Install CPU PyTorch first so pip doesn't resolve the heavy CUDA wheel when
# it later processes the package's torch dependency.
RUN pip install --no-cache-dir \
    torch \
    --extra-index-url https://download.pytorch.org/whl/cpu

# Install the built wheel (includes numpy, opencv, torch) and model weights.
COPY --from=builder /dist/*.whl /tmp/
RUN pip install --no-cache-dir /tmp/*.whl

# Pillow is an optional runtime dep (for WEBP/GIF/JFIF support); test samples
# include these formats so we install it explicitly here.
# pytest is the only dev dependency needed.
RUN pip install --no-cache-dir Pillow pytest

# Test inputs only — no source tree in this image.
# tests/testdata/images/ contains all sample images (flat, no subdirs).
COPY tests/ tests/

CMD ["pytest", "tests/", "-v"]
